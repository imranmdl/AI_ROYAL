{
  "name": "royal-erp-server",
  "version": "1.1.0",
  "description": "Production Backend for Royal Tiles ERP",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "npx tsx server.ts",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:android": "npm run mobile:build && npx cap open android",
    "mobile:ios": "npm run mobile:build && npx cap open ios",
    "mobile:run:android": "npm run mobile:build && npx cap run android",
    "mobile:run:ios": "npm run mobile:build && npx cap run ios",
    "test:logic": "node tests/logic-only.mjs",
    "test:api": "node tests/regression.mjs",
    "test": "node tests/logic-only.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.42.0",
    "@types/compression": "^1.8.1",
    "@vitejs/plugin-react": "^5.1.4",
    "body-parser": "^1.20.2",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "fs-extra": "^11.3.3",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.3",
    "mysql2": "^3.9.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.3.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}